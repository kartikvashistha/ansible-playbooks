{% if common_machine_type == "personal" %}
Host *
  SetEnv TERM=xterm-256color
  {% if common_os | lower == "fedora" -%}
  IdentityAgent ~/.1password/agent.sock
  {% endif %}
{% if common_os | lower =="macosx" -%}
  IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
{% endif %}

Host velen
  HostName velen.home.arpa
  User {{ vault_velen_ansible_user }}

Host oxenfurt
  HostName oxenfurt.home.arpa
  User {{ vault_oxenfurt_ansible_user }}
{% endif -%}
